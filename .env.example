# Formspree form ID for the contact form (https://formspree.io).
VITE_FORMSPREE_ID=your_formspree_form_id_here

# Production site URL. Used for canonical/OG tags and to template
# public/sitemap.xml + public/robots.txt at build time.
VITE_SITE_URL=https://ajlee.com.au

# Optional. Google Analytics 4 measurement ID (e.g. G-XXXXXXXXXX).
# Leave blank to ship no analytics.
VITE_GA_ID=

# Optional. Sentry DSN. Leave blank to ship no error monitoring.
# To enable: see README "Error monitoring".
VITE_SENTRY_DSN=

# Supabase — powers the admin dashboard and public listing reads.
VITE_SUPABASE_URL=https://tqloxgeddhlursgpyeyk.supabase.co
VITE_SUPABASE_ANON_KEY=

# Admin password is NOT a Vite var. It lives as a Supabase Edge Function
# secret only (set via `supabase secrets set ADMIN_PASSWORD=...`) so it
# never reaches the browser bundle.
